{
  "name": "dice-roller-cool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "prettier --write \"{,!(.next|dist|node_modules)/**/}!(package-lock).{json,md,js,jsx,ts,tsx,css,scss}\"",
    "lint": "node ./node_modules/eslint/bin/eslint.js --ext .ts --ext .tsx --fix .",
    "pre-commit": "lint-staged",
    "pre-push": "npm run lint && npm run typecheck",
    "//": "TODO its kind of stupid to store the port right here in the start command",
    "start": "next start -p 8100",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@material-ui/core": "4.11.0",
    "@types/node": "14.0.27",
    "@types/pg": "7.14.5",
    "@types/react": "16.9.52",
    "@types/react-dom": "16.9.8",
    "@types/uuid": "8.3.0",
    "cross-env": "7.0.2",
    "date-fns": "2.16.1",
    "next": "9.5.5",
    "pg": "8.4.1",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "typescript": "4.0.3",
    "uuid": "8.3.1"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "4.4.1",
    "@typescript-eslint/parser": "4.4.1",
    "eslint": "7.11.0",
    "eslint-config-prettier": "6.12.0",
    "eslint-plugin-react": "7.21.4",
    "eslint-plugin-react-hooks": "4.1.2",
    "husky": "4.3.0",
    "lint-staged": "10.4.0",
    "prettier": "2.1.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run pre-commit",
      "pre-push": "npm run pre-push"
    }
  },
  "lint-staged": {
    "*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "node ./node_modules/eslint/bin/eslint.js --ext .ts --ext .tsx --fix",
      "prettier --write"
    ]
  }
}
